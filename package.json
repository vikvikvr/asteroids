{
  "name": "asteroids-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@code-dot-org/p5.play": "^1.3.16-cdo",
    "lodash": "^4.17.21",
    "p5": "^1.3.1",
    "uuid": "^8.3.2"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "test": "vitest",
    "deploy": "gh-pages -d build"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended"
    ],
    "env": {
      "node": true
    },
    "rules": {
      "no-var": "error",
      "class-methods-use-this": "error",
      "block-scoped-var": "error",
      "no-empty-function": "error",
      "no-invalid-this": "error",
      "no-lone-blocks": "error",
      "no-multi-str": "error",
      "no-param-reassign": "error",
      "no-use-before-define": "error",
      "line-comment-position": [
        "error",
        {
          "position": "above"
        }
      ],
      "max-depth": [
        "error",
        4
      ],
      "max-statements": [
        "error",
        10
      ],
      "max-params": [
        "error",
        4
      ],
      "no-mixed-operators": "error",
      "no-negated-condition": "error",
      "no-nested-ternary": "error"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/lodash": "^4.14.168",
    "@types/node": "^20.11.0",
    "@types/p5": "^0.9.1",
    "@types/uuid": "^8.3.0",
    "gh-pages": "^3.1.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.5.0"
  }
}
